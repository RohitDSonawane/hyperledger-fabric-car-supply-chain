# ##########################################################
# # CAR SUPPLY CHAIN - 5-PC DISTRIBUTED SETUP (.env)       #
# ##########################################################
# 
# IMPORTANT: Copy this to .env (gitignored) and fill in 
# your ZeroTier Managed IPs.
# 

# --- TOPOLOGY MODE ---
# single | distributed
HLF_MODE=distributed

# --- ZEROTIER NETWORK ENDPOINTS (PLACEHOLDERS) ---
# Replace with your actual ZeroTier Managed IPs for each machine

PC1_IP=10.147.x.x   # Manager (Orderer + Artifact Source)
PC2_IP=10.147.x.x   # Manufacturer Org
PC3_IP=10.147.x.x   # Showroom Org
PC4_IP=10.147.x.x   # Customer Org
PC5_IP=10.147.x.x   # Explorer + Monitoring

# --- COMPONENT MAPPING (CANONICAL NAMES) ---
ORDERER_HOST=${PC1_IP}
MANUFACTURERP_HOST=${PC2_IP}
SHOWROOMP_HOST=${PC3_IP}
CUSTOMERP_HOST=${PC4_IP}
EXPLORER_HOST=${PC5_IP}

# --- SYSTEM GENESIS ---
# Leave as 127.0.0.1 if running on PC1; 
# change to PC1_IP if you need remote lookup.
LOCAL_OVERRIDE=false

# --- SECURITY ---
# ZeroTier Private network range (e.g. 10.147.0.0/16)
NETWORK_SUBNET=10.147.0.0/16
